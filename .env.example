# Radio Ad Pipeline — Frontend Environment Variables
# Copy this file to .env and adjust for your environment.

# Base URL of the FastAPI harvest backend (no trailing slash).
# Leave blank to use the Vite dev proxy (recommended for local dev).
# Set to a full URL (e.g. http://192.168.1.10:8081) to bypass the proxy.
VITE_RADIO_API_BASE_URL=
